@startuml
title Get All Reservations (Admin)

participant "Admin Client" as client
participant "<<AuthMiddleware>>\nprotect + authorize(admin)" as middleware
participant "<<Controller>>\ngetAllReservations()" as controller
participant "<<Model>>\nReservation" as model
database "<<MongoDB>>\nreservations" as db

client -> middleware : GET /reservations
activate middleware

middleware -> controller : authorized admin
activate controller

controller -> model : find().populate(user, restaurant)
activate model

model -> db : query reservations
db --> model : reservations
deactivate model

controller --> client : 200 OK + reservations
deactivate controller
deactivate middleware

@enduml