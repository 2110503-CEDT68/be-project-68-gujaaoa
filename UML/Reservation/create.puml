@startuml
title Create Reservation (POST /api/v1/reservations)

participant "Client" as client
participant "<<AuthMiddleware>>\nprotect" as middleware
participant "<<Controller>>\ncreateReservation()" as controller
participant "<<Model>>\nRestaurant" as restaurantModel
participant "<<Model>>\nReservation" as reservationModel
database "<<MongoDB>>\nreservations" as db

client -> middleware : POST /reservations (JWT)
activate middleware

middleware -> controller : req.user
activate controller

controller -> restaurantModel : findById(restaurant_id)
activate restaurantModel
restaurantModel --> controller : restaurant / null
deactivate restaurantModel

alt restaurant not found
  controller --> client : 404 Restaurant not found
else restaurant exists
  controller -> reservationModel : findOne(user_id, restaurant_id, date)
  activate reservationModel
  reservationModel --> controller : existed / null
  deactivate reservationModel

  alt duplicated reservation
    controller --> client : 400 Already reserved
  else not duplicated
    controller -> controller : validate table_count <= 3

    alt table_count > 3
      controller --> client : 400 Limit exceeded
    else valid
      controller -> reservationModel : create(reservation)
      activate reservationModel
      reservationModel -> db : insert document
      db --> reservationModel : reservation
      deactivate reservationModel

      controller --> client : 201 Created
    end
  end
end

deactivate controller
deactivate middleware
@enduml