@startuml
title Get My Reservations (GET /api/v1/reservations/me)

participant "Client" as client
participant "<<AuthMiddleware>>\nprotect" as middleware
participant "<<Controller>>\ngetMyReservations()" as controller
participant "<<Model>>\nReservation" as model
database "<<MongoDB>>\nreservations" as db

client -> middleware : GET /reservations/me (JWT)
activate middleware

middleware -> controller : req.user
activate controller

controller -> model : find({ user_id })
activate model

model -> db : query reservations
db --> model : reservations
deactivate model

controller --> client : 200 OK + reservations
deactivate controller
deactivate middleware

@enduml